# Copy to .env and adjust. Never commit real secrets.
OLLAMA_URL=http://localhost:11434
# Vision model. The local /vlm/match decomposes into single-image reads + deterministic comparison,
# and /vlm/measure grounds bounding boxes + computes cm — both reliable on small models like the 3B.
OLLAMA_MODEL=qwen2.5vl:3b
# OLLAMA_MODEL=moondream   # tiny CPU fallback — single image only, weak schema adherence
#
# GPU note: set to 0 to force FULL CPU. REQUIRED if image inference returns HTTP 500 with
# "CUDA error: a PTX JIT compilation failed" (broken/mismatched CUDA) — text works on GPU but the
# vision path does not. CPU is slower (~60s/call) but correct. Unset = let Ollama decide.
OLLAMA_NUM_GPU=0
# CPU inference is slow and /vlm/match makes two model calls — give it headroom.
VLM_TIMEOUT=300
