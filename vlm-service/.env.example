# Copy to .env and adjust. Never commit real secrets.
OLLAMA_URL=http://localhost:11434
# qwen2.5vl handles TWO images (needed for /vlm/match) and follows the JSON schema well.
OLLAMA_MODEL=qwen2.5vl:latest
# OLLAMA_MODEL=moondream   # tiny CPU fallback — SINGLE image only, weak schema adherence
# Force layers to CPU on small-VRAM cards: 0 = full CPU. Unset = let Ollama decide.
OLLAMA_NUM_GPU=
VLM_TIMEOUT=120
