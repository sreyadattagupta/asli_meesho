# Copy to .env and adjust. Never commit real secrets.
OLLAMA_URL=http://localhost:11434
# Vision model. The local /vlm/match decomposes into single-image reads + deterministic comparison,
# and /vlm/measure grounds bounding boxes + computes cm — both reliable on small models like the 3B.
OLLAMA_MODEL=qwen2.5vl:3b
# OLLAMA_MODEL=moondream   # tiny CPU fallback — single image only, weak schema adherence
#
# GPU note: 99 = full GPU offload (FAST — ~1s/call warm). qwen2.5vl:3b is ~2.9 GB and fits a 4 GB
# card (e.g. GTX 1650) at 100% GPU. Prefer this. Fall back to 0 (FULL CPU, ~60s/call) only if image
# inference 500s with "CUDA error: a PTX JIT compilation failed" — a broken/mismatched CUDA toolchain
# where text works on GPU but the vision path doesn't (fixed on ollama ≥0.32). Unset = let Ollama decide.
OLLAMA_NUM_GPU=99
# Keep the model + vision projector resident between calls so the demo doesn't re-pay the cold load.
OLLAMA_KEEP_ALIVE=30m
# Ceiling per call — generous for the one-time cold vision load (~17s) and the CPU fallback.
VLM_TIMEOUT=300

# ── Generative VLM backend ───────────────────────────────────────────────────
# ollama (local, default) | gemini (deployed HF Space — no GPU). The deterministic CV
# (cosine, homography, OCR, calibration) is identical either way.
VLM_BACKEND=ollama
GEMINI_API_KEY=                   # required when VLM_BACKEND=gemini
GEMINI_MODEL=gemini-2.0-flash

# ── Agent 1 same-item gate (CLIP via ONNX; DINOv2 = reported evidence) ───────
# The Live-Proof same-item decision is a CLIP/max cosine gate, calibrated on Marqo/deepfashion-inshop
# (scripts/eval_matcher.py) and validated on the real proof fixtures. Defaults live in
# models/same_item_calibration.json; these env vars override them. Threshold is PROVISIONAL — set it
# from your own catalog-vs-live data before go-live (0.896 = the eval's strict ~5% false-accept point).
SAME_ITEM_THRESHOLD=0.78
SAME_ITEM_GATE_SIGNAL=clip/max          # clip/max (clutter-robust) | clip/whole (peak semantic AUC)
SAME_ITEM_EVIDENCE_SIGNAL=dino/max/cls  # DINOv2 signal reported alongside (non-gating)
# ONNX model locations (defaults resolve under models/). Only set to relocate the pinned artifacts.
# DINOV2_ONNX_PATH=models/dinov2-small/model.onnx
# CLIP_ONNX_PATH=models/clip-vit-b32/model.onnx

# ── Legacy embed.py same-product thresholds (perceptual-hash fallback path only) ──
# Used ONLY when neither ONNX backbone is present (embed.py CLIP/phash). Not the primary gate.
MATCH_THRESHOLD=0.90
MATCH_HI=0.95
MATCH_LO=0.70

# ── Agent 1 reverse image search (component 4) ───────────────────────────────
# SerpAPI Google Lens key — live open-web reverse search + evidence extraction. TRIGGER only.
# Blank ⇒ the reverse stage degrades (available=false); the pipeline still scores on internal
# signals. Free tier ~100/mo; results are hash-cacheable. Set as an HF Space secret when deployed.
SERPAPI_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated origins allowed to call this service. Add the deployed Vercel origin here
# (as an HF Space secret) so the judge-facing demo can reach the CV pipeline.
ALLOWED_ORIGINS=http://localhost:3000
