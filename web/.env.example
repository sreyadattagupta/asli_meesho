# Copy to .env.local (gitignored). Never commit real secrets.

# ── Reverse-image TRIGGER ────────────────────────────────────────────────────
# SerpAPI Google Lens (free tier ~100/mo): https://serpapi.com/manage-api-key
# Leave BLANK to fall back to the next trigger source / built-in mock.
SERPAPI_KEY=
TRIGGER_SOURCE=serpapi            # serpapi | qdrant (local full demo) | mock

# ── VLM provider ─────────────────────────────────────────────────────────────
VLM_PROVIDER=ollama               # ollama (local, $0/call) | gemini (deployed) | mock
VLM_SERVICE_URL=http://localhost:8000
VLM_HTTP_TIMEOUT_MS=60000          # per-call ceiling; on timeout → degrade to labelled Mock
GEMINI_API_KEY=                   # deployed cloud VLM provider

# Agent 1 (Live Proof) strict same-product pass bar. A live photo must match the catalog at ≥ this
# confidence to pass; two failed attempts block the listing. Configurable — the orchestrator floors
# its risk-adaptive bar here (invariant #7).
NEXT_PUBLIC_MATCH_THRESHOLD=0.9

# ── Data backend (Repo seam) ─────────────────────────────────────────────────
DATA_BACKEND=memory               # memory (local) | supabase (deployed)
SUPABASE_URL=                     # e.g. https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # server-side ONLY — never NEXT_PUBLIC, never commit

# ── Auth (email + password, accounts in MongoDB, signed-JWT session) ─────────
# Sign up / sign in with email + password; accounts persist in MongoDB; session is a signed cookie.
MONGODB_URI=                      # mongodb+srv://<user>:<pass>@<cluster>/?appName=...  (never commit)
MONGODB_DB=asli                   # database name for the accounts collection
SESSION_SECRET=                   # openssl rand -hex 32 (HMAC key for the session JWT)
APP_BASE_URL=http://localhost:3000
# Dev-only persona bypass buttons on /login (never active in production):
# AUTH_TEST_BYPASS=1

# ── Challenge codes (invariant #3: dynamic + time-bound + single-use) ────────
CHALLENGE_TTL_SECONDS=300

# ── Client flags (non-secret only) ───────────────────────────────────────────
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_DEFAULT_LOCALE=en     # en | hi
