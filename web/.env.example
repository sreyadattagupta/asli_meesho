# Copy to .env.local (gitignored). Never commit real secrets.

# ── The ONLY API key you need to fill ────────────────────────────────────────
# SerpAPI Google Lens — powers the reverse-image TRIGGER (free tier ~100/mo).
# Get it at: https://serpapi.com/manage-api-key
# Leave BLANK to use the built-in mock (the demo still works end-to-end).
SERPAPI_KEY=

# ── No key needed below ──────────────────────────────────────────────────────
# Our self-hosted VLM service (FastAPI + local Ollama). API routes proxy to this.
VLM_SERVICE_URL=http://localhost:8000

# Challenge code TTL in seconds (dynamic, time-bound — invariant #3).
CHALLENGE_TTL_SECONDS=300
